# Canonical public URL — used as the OAuth redirectTo base so deployment-specific
# Vercel URLs never end up as the redirect target. Set to production URL in Vercel
# env vars; omit locally (falls back to window.location.origin for localhost dev).
NEXT_PUBLIC_SITE_URL=https://azurdle.vercel.app

# Supabase (free tier project) — https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only. Never expose via NEXT_PUBLIC_*, never log, never commit.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret for HMAC-signing the anonymous-play progress cookie.
# Generate with: openssl rand -hex 32
# Server-only. Never expose via NEXT_PUBLIC_*, never log, never commit.
ANONYMOUS_PROGRESS_SECRET=your-32-byte-hex-secret

# GitHub Models — the standing puzzle-generation provider (see CLAUDE.md).
# Build/cron-time only, never called from app runtime. Personal access
# token with `models: read` scope.
# NOTE: in GitHub Actions this same value is stored under the secret name
# MODELS_PAT, not GITHUB_MODELS_TOKEN — Actions rejects secret names
# starting with "GITHUB_" (reserved for GitHub's own auto-populated vars).
# The workflow maps secrets.MODELS_PAT onto this GITHUB_MODELS_TOKEN env
# var name, which is what the code actually reads. Locally, use this exact
# name below — only the Actions secret name differs.
GITHUB_MODELS_TOKEN=your-github-models-pat

# Ollama Cloud — local-only dev/testing convenience, never used in the
# production cron. Set MODEL_PROVIDER=ollama to switch to it locally.
# MODEL_PROVIDER=ollama
# OLLAMA_API_KEY=your-ollama-cloud-api-key

# Tavily — web search tool available to the fact-checker during
# calibration (scripts/lib/calibration.ts's passesFactCheck), so it can
# verify claims about newer/less-common Azure services instead of relying
# solely on the model's training data. Build/cron-time only. Free tier:
# 1,000 credits/month, no card required.
TAVILY_API_KEY=your-tavily-api-key
