# editor / IDE
.vscode/*
!.vscode/extensions.json
.idea

# OS
Thumbs.db

# local agent/skill tooling (machine-specific, not project source)
.claude/skills
.claude/settings.local.json
.agents
.impeccable
skills-lock.json
.mcp.json

